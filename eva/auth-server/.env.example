# GitHub OAuth app credentials
# Create one at https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Must match the callback URL registered in your GitHub OAuth app
# Local dev: http://localhost:4000/auth/github/callback
AUTH_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Origin of the Vite UI — used for CORS and post-auth redirects
UI_ORIGIN=http://localhost:5173

# Secret used to sign JWT tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Comma-separated list of allowed GitHub emails (leave empty to allow everyone)
ALLOWED_EMAILS=

PORT=4000

# LiveKit credentials — used server-side only to generate participant tokens
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# Pinecone
PINECONE_INDEX_HOST=
PINECONE_API_TOKEN=
OPENAI_API_KEY=
