# ── Auth server ───────────────────────────────────────────────────────────────

# GitHub OAuth app — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Must match the callback URL registered in your GitHub OAuth app.
# Dev:  http://localhost/auth/github/callback
# Prod: https://${DOMAIN}/auth/github/callback
AUTH_CALLBACK_URL=http://localhost/auth/github/callback

# Origin of the UI — used for CORS and post-auth redirects.
# Dev:  http://localhost
# Prod: https://${DOMAIN}
UI_ORIGIN=http://localhost

# Secret used to sign JWT tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Comma-separated list of allowed GitHub emails (leave empty to allow all)
ALLOWED_EMAILS=

# ── LiveKit (shared by auth-server and voice-agent) ───────────────────────────

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Voice agent AI providers ──────────────────────────────────────────────────

OPENAI_API_KEY=
DEEPGRAM_API_KEY=
INWORLD_API_KEY=

# ── UI build-time config ──────────────────────────────────────────────────────
# These are baked into the JS bundle and visible in the browser.

VITE_AGENT_NAME=eva
VITE_APIVIDEO_API_KEY=

# ── Traefik / TLS (production self-hosting only) ──────────────────────────────
# Leave empty for local development — Traefik will serve HTTP on port 80 only.
#
# In production:
#   1. Set DOMAIN to your public hostname (e.g. eva.example.com)
#   2. Set ACME_EMAIL to the email Let's Encrypt should use for notifications
#   3. Update AUTH_CALLBACK_URL and UI_ORIGIN above to use https://${DOMAIN}
#   4. Open ports 80 and 443 on your firewall (required for ACME HTTP-01)
#   5. Deploy with:
#        docker compose -f docker-compose.yaml -f docker-compose.prod.yaml up -d
DOMAIN=
ACME_EMAIL=
