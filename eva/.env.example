# ── Auth server ───────────────────────────────────────────────────────────────

# GitHub OAuth app — https://github.com/settings/developers
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Must match the callback URL registered in your GitHub OAuth app
AUTH_CALLBACK_URL=http://localhost:4000/auth/github/callback

# Origin of the UI — used for CORS and post-auth redirects
UI_ORIGIN=http://localhost:8080

# Secret used to sign JWT tokens
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# Comma-separated list of allowed GitHub emails (leave empty to allow all)
ALLOWED_EMAILS=

# ── LiveKit (shared by auth-server and voice-agent) ───────────────────────────

LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── Voice agent AI providers ──────────────────────────────────────────────────

OPENAI_API_KEY=
DEEPGRAM_API_KEY=
INWORLD_API_KEY=

# ── UI build-time config ──────────────────────────────────────────────────────
# These are baked into the JS bundle and visible in the browser.

VITE_AGENT_NAME=eva
VITE_APIVIDEO_API_KEY=
