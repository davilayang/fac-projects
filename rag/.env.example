# Dagster + Pipeline DB (single Postgres instance)
DAGSTER_PG_USERNAME=dagster
DAGSTER_PG_PASSWORD=...
DAGSTER_PG_DB=dagster
DAGSTER_PG_HOST=localhost
DAGSTER_PG_PORT=5432

HF_TOKEN=op://employee/api-keys/HF_TOKEN
OPENAI_KEY=op://employee/api-keys/OPENAI_KEY
ANTHROPIC_API_KEY=op://employee/api-keys/ANTHROPIC_API_KEY

DB_USERNAME=op://employee/db-credentials/DB_USERNAME
DB_PASSWORD=op://employee/db-credentials/DB_PASSWORD
DB_DATABASE=op://employee/db-credentials/DB_DATABASE

LOG_LEVEL=INFO
SQL_ECHO=false

S3_ACCESS_KEY=op://employee/api-keys/S3_ACCESS_KEY
S3_SECRET_KEY=op://employee/api-keys/S3_SECRET_KEY
S3_BUCKET_NAME=vertuvian

GITHUB_CLIENT_ID=op://employee/api-keys/GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=op://employee/api-keys/GITHUB_CLIENT_SECRET
SESSION_SECRET=op://employee/api-keys/SESSION_SECRET
ALLOWED_EMAILS=rihards.dev@pm.me
COOKIE_SECURE=true
